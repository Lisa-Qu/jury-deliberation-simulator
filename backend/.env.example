# Copy to .env and fill in. NEVER commit the real .env.
# Pick ONE provider (DeepSeek is preferred automatically if its key is present).

# --- DeepSeek (OpenAI-compatible chat; no embeddings → RAG uses local embedder) ---
DEEPSEEK_API_KEY=your-deepseek-key-here
# JURY_DEEPSEEK_MODEL=deepseek-chat

# --- Google Gemini (chat + text-embedding-004) ---
# GEMINI_API_KEY=your-google-ai-studio-key-here
# JURY_MODEL=gemini-1.5-flash
# JURY_EMBED_MODEL=models/text-embedding-004

# Force a provider explicitly (otherwise inferred from whichever key is set):
# JURY_PROVIDER=deepseek   # or: gemini
